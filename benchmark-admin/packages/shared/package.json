{
  "name": "@benchmark-admin/shared",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./dist/env.js"
    },
    "./db/schema": {
      "types": "./src/db/schema.ts",
      "default": "./dist/db/schema.js"
    },
    "./schemas/assets": {
      "types": "./src/schemas/assets.ts",
      "default": "./dist/schemas/assets.js"
    },
    "./schemas/benchmark": {
      "types": "./src/schemas/benchmark.ts",
      "default": "./dist/schemas/benchmark.js"
    },
    "./schemas/prompts": {
      "types": "./src/schemas/prompts.ts",
      "default": "./dist/schemas/prompts.js"
    },
    "./constants/orderings": {
      "types": "./src/constants/orderings.ts",
      "default": "./dist/constants/orderings.js"
    },
    "./constants/question-types": {
      "types": "./src/constants/question-types.ts",
      "default": "./dist/constants/question-types.js"
    },
    "./benchmark/categoryTree": {
      "types": "./src/benchmark/categoryTree.ts",
      "default": "./dist/benchmark/categoryTree.js"
    },
    "./lib/prompts/character": {
      "types": "./src/lib/prompts/character.ts",
      "default": "./dist/lib/prompts/character.js"
    },
    "./lib/prompts/scene": {
      "types": "./src/lib/prompts/scene.ts",
      "default": "./dist/lib/prompts/scene.js"
    },
    "./lib/prompts/prop": {
      "types": "./src/lib/prompts/prop.ts",
      "default": "./dist/lib/prompts/prop.js"
    },
    "./lib/prompts/extract-fields": {
      "types": "./src/lib/prompts/extract-fields.ts",
      "default": "./dist/lib/prompts/extract-fields.js"
    },
    "./lib/exports/headers": {
      "types": "./src/lib/exports/headers.ts",
      "default": "./dist/lib/exports/headers.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.12.0",
    "drizzle-orm": "^0.38.4",
    "drizzle-zod": "^0.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "typescript": "^5.7.3"
  }
}
